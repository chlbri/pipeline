{
  "name": "@bemedev/pipe",
  "version": "1.4.0",
  "description": "A utility for creating and managing pipelines in Typescript.",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/pipeline"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "require": "./lib/index.cjs"
    },
    "./package.json": "./package.json",
    "./extensions": {
      "types": "./lib/extensions/index.d.ts",
      "import": "./lib/extensions/index.js",
      "require": "./lib/extensions/index.cjs"
    },
    "./extensions/numbers": {
      "types": "./lib/extensions/numbers/index.d.ts",
      "import": "./lib/extensions/numbers/index.js",
      "require": "./lib/extensions/numbers/index.cjs"
    },
    "./extensions/common": {
      "types": "./lib/extensions/common/index.d.ts",
      "import": "./lib/extensions/common/index.js",
      "require": "./lib/extensions/common/index.cjs"
    },
    "./extensions/*": {
      "types": "./lib/extensions/*.d.ts",
      "import": "./lib/extensions/*.js",
      "require": "./lib/extensions/*.cjs"
    }
  },
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "typescript",
    "pipeline",
    "utility",
    "functions"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "_preconfig": "chmod +x .husky/commit-msg && chmod +x .husky/pre-commit",
    "build": "pnpm run rm:lib && pnpm run rolldown",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade:fast && pnpm run ci",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "config:vitest": "pnpm add -D @vitest/coverage-v8@4.1.4 @vitest/ui@4.1.4 vitest@4.1.4",
    "_lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "build:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run build",
    "p-q": "pretty-quick",
    "posttest": "pnpm run fmt",
    "prepare": "husky",
    "prepublishOnly": "",
    "pretest": "pnpm run build && pnpm run size",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rm": "pnpx rimraf ./node_modules ./pnpm-lock.yaml",
    "rm:lib": "pnpx rimraf ./lib",
    "rolldown": "rolldown -c",
    "test:coverage": "vitest run",
    "test": "pnpm run test:coverage",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package && pnpm run config:vitest",
    "size": "size-limit",
    "upgrade:fast": "pnpm up --latest && pnpm run config:vitest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/dev-utils": "^0.6.4",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "4.1.4",
    "glob": "^13.0.6",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0-rc.17",
    "size-limit": "^12.1.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
